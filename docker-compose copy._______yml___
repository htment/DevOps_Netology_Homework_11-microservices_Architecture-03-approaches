services:

  # =========================
  # Elasticsearch (хранилище логов)
  # =========================
  elasticsearch:
    image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0
    container_name: elasticsearch
    environment:
      - discovery.type=single-node
      - xpack.security.enabled=true
      - ELASTIC_PASSWORD=qwerty123456
      - ES_JAVA_OPTS=-Xms1g -Xmx1g
    ports:
      - "9200:9200"
    volumes:
      - es-data:/usr/share/elasticsearch/data
    networks:
      - app-network
    healthcheck:
      test: ["CMD-SHELL", "curl -s http://localhost:9200/_cluster/health | grep -q status"]
      interval: 10s
      timeout: 5s
      retries: 20

  # =========================
  # Kibana (UI для Elasticsearch)
  # =========================
  kibana:
    image: docker.elastic.co/kibana/kibana:8.11.0
    container_name: kibana
    environment:
      - ELASTICSEARCH_HOSTS=http://elasticsearch:9200
      - ELASTICSEARCH_USERNAME=elastic
      - ELASTICSEARCH_PASSWORD=qwerty123456
      - xpack.security.encryptionKey=someverylongencryptionkey123
      - xpack.encryptedSavedObjects.encryptionKey=someverylongencryptionkey123
      - xpack.reporting.encryptionKey=someverylongencryptionkey123
    ports:
      - "5601:5601"
    depends_on:
      elasticsearch:
        condition: service_healthy
    networks:
      - app-network

  # =========================
  # INIT: установка kibana_system пароля
  # =========================
  create-kibana-user:
    image: curlimages/curl:8.5.0
    container_name: create-kibana-user
    depends_on:
      elasticsearch:
        condition: service_healthy
    entrypoint: ["/bin/sh", "-c"]
    command: |
      until curl -s -u elastic:qwerty123456 http://elasticsearch:9200 >/dev/null; do
        echo "waiting elasticsearch..."
        sleep 5
      done

      curl -X POST -u elastic:qwerty123456 \
        http://elasticsearch:9200/_security/user/kibana_system/_password \
        -H "Content-Type: application/json" \
        -d '{"password":"qwerty123456"}'

      echo "kibana_system password set"
    networks:
      - app-network

  # =========================
  # API Gateway (пример микросервиса)
  # =========================
  api-gateway:
    image: nginx:alpine
    container_name: api-gateway
    ports:
      - "8080:80"
    networks:
      - app-network

  # =========================
  # Filebeat (сбор логов)
  # =========================
  filebeat:
    image: docker.elastic.co/beats/filebeat:8.11.0
    container_name: filebeat
    user: root
    volumes:
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - app-network

  # =========================
  # service-a (микросервис)
  # =========================
  service-a:
    image: alpine
    container_name: service-a
    command: ["sh", "-c", "while true; do echo service-a; sleep 5; done"]
    networks:
      - app-network

  # =========================
  # service-b (микросервис)
  # =========================
  service-b:
    image: alpine
    container_name: service-b
    command: ["sh", "-c", "while true; do echo service-b; sleep 5; done"]
    networks:
      - app-network

  # =========================
  # service-c (микросервис)
  # =========================
  service-c:
    image: alpine
    container_name: service-c
    command: ["sh", "-c", "while true; do echo service-c; sleep 5; done"]
    networks:
      - app-network

# =========================
# Volumes
# =========================
volumes:
  es-data:

# =========================
# Network
# =========================
networks:
  app-network: